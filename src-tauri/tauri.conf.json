{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "J.H AI Agent",
  "version": "0.1.0",
  "identifier": "com.jh-ai-agent.app",
  "build": {
    "devUrl": "http://localhost:1430",
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "J.H AI Agent",
        "width": 1200,
        "height": 800,
        "decorations": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
